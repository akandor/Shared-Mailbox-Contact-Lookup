## Environment variables configuration for the Shared Mailbox Contact Lookup application.

# Azure AD app registration details
TENANT_ID=your-tenant-id
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
MAILBOX_EMAIL=shared@company.com
# Certificate auth (takes precedence over CLIENT_SECRET if both set)
CERT_KEY_PATH=./certs/private.key
CERT_THUMBPRINT=your-cert-thumbprint
#Server configuration
SYNC_INTERVAL_MINUTES=5
PORT=3000
TRUSTED_HOSTS=localhost,127.0.0.1
USERNAME=your-username
PASSWORD=your-password
HTTPS=false
HTTPS_KEY_PATH=./certs/server.key
HTTPS_CERT_PATH=./certs/server.crt
HTTPS_CA_PATH=./certs/ca.crt
HTTPS_ONLY=false

# Name display format: firstname, lastname, company
#   firstname → First Last (Company)
#   lastname  → Last, First (Company)
#   company   → Company (First Last)
NAME_FORMAT=firstname
